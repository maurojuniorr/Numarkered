<Template>
  <SetVariable name="BgColor">#0F1116</SetVariable>
  <SetVariable name="SignalHighColor">#00FFFF</SetVariable> 
  <SetVariable name="SignalMidColor">#00FF44</SetVariable>  
  <SetVariable name="SignalLowColor">#FF0044</SetVariable>  
  <SetVariable name="SignalColor">#2A2D35</SetVariable>
  <SetVariable name="SignalRGBHighColor">blue</SetVariable>
  <SetVariable name="SignalRGBMidColor">green</SetVariable>
  <SetVariable name="SignalRGBLowColor">red</SetVariable>
  <!-- <SetVariable name="SignalColor">#32323c</SetVariable> -->
  <SetVariable name="BeatColor">#3a3a3a3a</SetVariable>
  <SetVariable name="PlayPosColor">#ffffffff</SetVariable>
  <SetVariable name="EndOfTrackColor">#EA0000</SetVariable>
  <WidgetGroup>
    <ObjectName>Waveform_Channel<Variable name="channel"/></ObjectName>
    <Layout>horizontal</Layout>
    <Size>0me,47me</Size>
    <Children>
      <WidgetGroup>
        <ObjectName>WaveformInfo</ObjectName>
        <Layout>vertical</Layout>
        <Size>140f,0me</Size>
        <MinimumSize>140,-1</MinimumSize>
        <SizePolicy>f,min</SizePolicy>
        <Align>top</Align>
        <Children>
          
          <WidgetGroup>
            <ObjectName>WaveformInfo_Header</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,20max</Size>
            <Children>
              <Label>
                <ObjectName>WaveformInfo_Title</ObjectName>
                <Text>Deck <Variable name="channel"/></Text>
              </Label>
            </Children>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
              <BindProperty>highlight</BindProperty>
            </Connection>
          </WidgetGroup>

          <WidgetGroup>
            <ObjectName>WaveformInfo_Data_Container</ObjectName>
            <Layout>vertical</Layout>
            <Size>0me,0me</Size>
            <Children>
              
              <WidgetGroup>
                <ObjectName>WaveformInfo_Key_Container</ObjectName>
                <Layout>horizontal</Layout>
                <Size>0me,0me</Size>
                <Children>
                  <WidgetGroup>
                    <ObjectName>WaveformInfo_LabelCell</ObjectName>
                    <Layout>horizontal</Layout>
                    <Children>
                      <Label>
                        <ObjectName>WaveformInfo_RowLabel</ObjectName>
                        <Text>KEY</Text>
                      </Label>
                    </Children>
                  </WidgetGroup>
                  <WidgetGroup>
                    <ObjectName>WaveformInfo_ValueCell</ObjectName>
                    <Layout>horizontal</Layout>
                    <Children>
                      <Key>
                        <ObjectName>WaveformInfo_Key</ObjectName>
                        <TooltipId>visual_key</TooltipId>
                        <Connection>
                          <ConfigKey>[Channel<Variable name="channel"/>],visual_key</ConfigKey>
                        </Connection>
                      </Key>
                    </Children>
                  </WidgetGroup>
                </Children>
              </WidgetGroup>

              <WidgetGroup>
                <ObjectName>WaveformInfo_Loopsize_Container</ObjectName>
                <Layout>horizontal</Layout>
                <Size>140f,0me</Size>
                <SizePolicy>f,min</SizePolicy>
                <Children>
                  <WidgetGroup>
                    <Layout>horizontal</Layout>
                    <SizePolicy>me,min</SizePolicy> <Children>
                      <Label>
                        <ObjectName>WaveformInfo_RowLabel</ObjectName>
                        <Text>LOOP</Text>
                        <Size>30f,0me</Size>
                      </Label>
                      <BeatSpinBox>
                        <ObjectName>WaveformInfo_BeatloopSizeSpinBox</ObjectName>
                        <TooltipId>beatloop_size</TooltipId>
                        <Value>[Channel<Variable name="channel"/>],beatloop_size</Value>
                        <SizePolicy>me,min</SizePolicy> </BeatSpinBox>
                    </Children>
                  </WidgetGroup>
                  
                  <WidgetGroup>
                    <Layout>horizontal</Layout>
                    <SizePolicy>me,min</SizePolicy>
                    <Children>
                      <Label>
                        <ObjectName>WaveformInfo_RowLabel</ObjectName>
                        <Text>JUMP</Text>
                        <Size>30f,0me</Size>
                      </Label>
                      <BeatSpinBox>
                        <ObjectName>WaveformInfo_BeatjumpSizeSpinBox</ObjectName>
                        <TooltipId>beatjump_size</TooltipId>
                        <Value>[Channel<Variable name="channel"/>],beatjump_size</Value>
                        <SizePolicy>me,min</SizePolicy>
                      </BeatSpinBox>
                    </Children>
                  </WidgetGroup>
                </Children>
              </WidgetGroup>

              <WidgetGroup>
                <ObjectName>WaveformInfo_Sync_Container</ObjectName>
                <Layout>horizontal</Layout>
                <SizePolicy>me,min</SizePolicy>
                <Align>center</Align>
                <Children>
                  <Template src="skin:templates/toggle_button.xml">
                    <SetVariable name="TooltipId">sync_enabled</SetVariable>
                    <SetVariable name="ObjectName">WaveformInfo_SyncButton</SetVariable>
                    <SetVariable name="Size">22f,22f</SetVariable>
                    <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],sync_enabled</SetVariable>
                  </Template>

                  <PushButton>
                    <TooltipId>sync_leader</TooltipId>
                    <ObjectName>WaveformInfo_SyncLeaderButton</ObjectName>
                    <Size>22f,22f</Size>
                    <NumberStates>2</NumberStates>
                    <State><Number>0</Number></State>
                    <State><Number>1</Number></State>
                    <Connection>
                      <ConfigKey>[Channel<Variable name="channel"/>],sync_leader</ConfigKey>
                      <ButtonState>LeftButton</ButtonState>
                    </Connection>
                    <Connection>
                      <ConfigKey>[Channel<Variable name="channel"/>],sync_leader</ConfigKey>
                      <BindProperty>highlight</BindProperty>
                    </Connection>
                  </PushButton>

                  <Template src="skin:templates/toggle_button.xml">
                    <SetVariable name="TooltipId">keylock</SetVariable>
                    <SetVariable name="ObjectName">WaveformInfo_KeylockButton</SetVariable>
                    <SetVariable name="Size">22f,22f</SetVariable>
                    <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],keylock</SetVariable>
                  </Template>
                </Children>
              </WidgetGroup>

              <WidgetGroup>
                <ObjectName>WaveformInfo_Quantize_Container</ObjectName>
                <Layout>horizontal</Layout>
                <SizePolicy>me,min</SizePolicy>
                <Align>center</Align>
                <Children>
                  <Template src="skin:templates/toggle_button.xml">
                    <SetVariable name="TooltipId">quantize</SetVariable>
                    <SetVariable name="ObjectName">WaveformInfo_QuantizeButton</SetVariable>
                    <SetVariable name="Size">22f,22f</SetVariable>
                    <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],quantize</SetVariable>
                  </Template>
                  
                  <Template src="skin:templates/toggle_button.xml">
                    <SetVariable name="TooltipId">bpmlock</SetVariable>
                    <SetVariable name="ObjectName">WaveformInfo_BeatlockButton</SetVariable>
                    <SetVariable name="Size">22f,22f</SetVariable>
                    <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],beatlock</SetVariable>
                  </Template>
                  
                  <Template src="skin:templates/toggle_button.xml">
                    <SetVariable name="TooltipId">beats_translate_curpos</SetVariable>
                    <SetVariable name="ObjectName">WaveformInfo_HalfBeatShiftButton</SetVariable>
                    <SetVariable name="Size">22f,22f</SetVariable>
                    <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],beats_translate_half</SetVariable>
                  </Template>
                </Children>
              </WidgetGroup>

              <WidgetGroup>
                <ObjectName>WaveformInfo_Fill</ObjectName>
                <SizePolicy>me,me</SizePolicy>
              </WidgetGroup>
              
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <Visual>
        <TooltipId>waveform_display</TooltipId>
        <ObjectName>Waveform<Variable name="channel"/></ObjectName>
        <Channel><Variable name="channel"/></Channel>
        <BgColor><Variable name="BgColor"/></BgColor>
        <SignalHighColor><Variable name="SignalHighColor"/></SignalHighColor>
        <SignalMidColor><Variable name="SignalMidColor"/></SignalMidColor>
        <SignalLowColor><Variable name="SignalLowColor"/></SignalLowColor>
        <SignalRGBHighColor><Variable name="SignalRGBHighColor"/></SignalRGBHighColor>
        <SignalRGBMidColor><Variable name="SignalRGBMidColor"/></SignalRGBMidColor>
        <SignalRGBLowColor><Variable name="SignalRGBLowColor"/></SignalRGBLowColor>
        <SignalColor><Variable name="SignalColor"/></SignalColor>
        <BeatColor><Variable name="BeatColor"/></BeatColor>
        <PlayPosColor><Variable name="PlayPosColor"/></PlayPosColor>
        <EndOfTrackColor><Variable name="EndOfTrackColor"/></EndOfTrackColor>
        
     
        
        <Mark>
          <Control>cue_point</Control>
          <Text>CUE</Text>
          <Color>#ff6000</Color>
          <TextColor>#ff6000</TextColor>
          <Align>bottom|left</Align>
        </Mark>
        <Mark>
          <Control>hotcue_1_position</Control>
          <Text>1</Text>
          <Color>#00FFFF</Color>
          <TextColor>#00ffff</TextColor>
          <Align>top|right</Align>
        </Mark>
        <Mark>
          <Control>hotcue_2_position</Control>
          <Text>2</Text>
          <Color>#00FF44</Color>
          <TextColor>#00FF44</TextColor>
          <Align>top|right</Align>
        </Mark>
        <Mark>
          <Control>hotcue_3_position</Control>
          <Text>3</Text>
          <Color>#FF5500</Color>
          <TextColor>#FF5500</TextColor>
          <Align>top|right</Align>
        </Mark>
        <Mark>
          <Control>hotcue_4_position</Control>
          <Text>4</Text>
          <Color>#FFFF00</Color>
          <TextColor>#FFFF00</TextColor>
          <Align>top|right</Align>
        </Mark>
        <Mark>
          <Control>hotcue_5_position</Control>
          <Text>5</Text>
          <Color>#9d4cfd</Color>
          <TextColor>#9d4cfd</TextColor>
          <Align>top|right</Align>
        </Mark>

        <Mark>
          <Control>loop_start_position</Control>
          <Text>LOOP IN</Text>
          <Color>#6ee128</Color>
          <TextColor>#6ee128</TextColor>
          <Align>bottom</Align>
        </Mark>
        <Mark>
          <Control>loop_end_position</Control>
          <Text>LOOP OUT</Text>
          <Color>#6ee128</Color>
          <TextColor>#6ee128</TextColor>
          <Align>bottom</Align>
        </Mark>
        <MarkRange>
          <StartControl>loop_start_position</StartControl>
          <EndControl>loop_end_position</EndControl>
          <EnabledControl>loop_enabled</EnabledControl>
          <Color>#6ee128</Color>
          <Opacity>0.8</Opacity>
          <DisabledColor>#acacac</DisabledColor>
          <DisabledOpacity>0.4</DisabledOpacity>
        </MarkRange>
      </Visual>
    </Children>
  </WidgetGroup>
</Template>
