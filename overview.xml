<Template>
  <WidgetGroup>
    <ObjectName>Overview</ObjectName>
    <Layout>vertical</Layout>
    <SizePolicy>me,me</SizePolicy>
    <Children>
      
      <WidgetGroup>
        <ObjectName>Waveforms_And_FX</ObjectName>
        <Layout>horizontal</Layout>
        <SizePolicy>me,me</SizePolicy>
        <Children>
          <WidgetGroup>
            <ObjectName>Waveforms_Container</ObjectName>
            <Layout>vertical</Layout>
            <SizePolicy>me,me</SizePolicy> 
            <Children>
              <Template src="skin:waveforms.xml"></Template>
            </Children>
          </WidgetGroup>

          <Template src="skin:effects.xml"></Template>
        </Children>
      </WidgetGroup>

      <WidgetGroup>
        <ObjectName>Decks</ObjectName>
        <Layout>horizontal</Layout>
        <SizePolicy>me,min</SizePolicy>
        <MaximumSize>-1,150</MaximumSize>
        <Children>
          <WidgetStack currentpage="[Skin],layer_left">
            <Children>
              <Template src="skin:deck.xml"><SetVariable name="channel">1</SetVariable><SetVariable name="side">left</SetVariable></Template>
              <Template src="skin:deck.xml"><SetVariable name="channel">3</SetVariable><SetVariable name="side">left</SetVariable></Template>
            </Children>
          </WidgetStack>
          <WidgetGroup><Size>4p,0me</Size></WidgetGroup>
          <WidgetStack currentpage="[Skin],layer_right">
            <Children>
              <Template src="skin:deck.xml"><SetVariable name="channel">2</SetVariable><SetVariable name="side">right</SetVariable></Template>
              <Template src="skin:deck.xml"><SetVariable name="channel">4</SetVariable><SetVariable name="side">right</SetVariable></Template>
            </Children>
          </WidgetStack>
        </Children>
      </WidgetGroup>

    </Children>
  </WidgetGroup>
</Template>