<Template>
  <WidgetGroup>
    <ObjectName>BeatFX_Container</ObjectName>
    <Layout>vertical</Layout>
    <Size>150max,0me</Size>
    <Children>
      <WidgetGroup>
        <ObjectName>BeatFX_Header</ObjectName>
        <Layout>vertical</Layout>
        <Size>20me,16p</Size>
        <Children>
          <Label>
            <ObjectName>BeatFX_Title</ObjectName>
            <Text>Beat FX</Text>
          </Label>
          <!-- Master FX level -->
          <VuMeter>
            <ObjectName>EffectMeter</ObjectName>
            <Size>0me,6max</Size>
            <PathBack scalemode="STRETCH">icons/effect_meter_bg.png</PathBack>
            <PathVu scalemode="STRETCH">icons/effect_meter_fg.png</PathVu>
            <Horizontal>true</Horizontal>
            <PeakHoldSize>0</PeakHoldSize>
            <PeakHoldTime>0</PeakHoldTime>
            <PeakFallTime>0</PeakFallTime>
            <PeakFallStep>0</PeakFallStep>
            <Connection>
              <ConfigKey>[EffectRack1_EffectUnit1],mix</ConfigKey>
            </Connection>
          </VuMeter>
        </Children>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>BeatFX_ChannelSelect</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <Label>
            <ObjectName>BeatFX_ChannelSelectLabel</ObjectName>
            <Text>CH SELECT</Text>
          </Label>
          <WidgetGroup>
            <ObjectName>BeatFX_ChannelButtons</ObjectName>
            <Layout>horizontal</Layout>
            <Children>
              <PushButton>
                <ObjectName>BeatFX_ChannelButton</ObjectName>
                <Size>0me,20p</Size>
                <NumberStates>2</NumberStates>
                <State>
                  <Number>0</Number>
                  <Text>1</Text>
                </State>
                <State>
                  <Number>1</Number>
                  <Text>1</Text>
                </State>
                <Connection>
                  <ConfigKey>[EffectRack1_EffectUnit1],group_[Channel1]_enable</ConfigKey>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>BeatFX_ChannelButton</ObjectName>
                <Size>0me,20p</Size>
                <NumberStates>2</NumberStates>
                <State>
                  <Number>0</Number>
                  <Text>2</Text>
                </State>
                <State>
                  <Number>1</Number>
                  <Text>2</Text>
                </State>
                <Connection>
                  <ConfigKey>[EffectRack1_EffectUnit1],group_[Channel2]_enable</ConfigKey>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>
      <Template src="skin:effect.xml">
        <SetVariable name="rack">1</SetVariable>
        <SetVariable name="unit">1</SetVariable>
        <SetVariable name="effect">1</SetVariable>
      </Template>
      <Template src="skin:effect.xml">
        <SetVariable name="rack">1</SetVariable>
        <SetVariable name="unit">1</SetVariable>
        <SetVariable name="effect">2</SetVariable>
      </Template>
      <Template src="skin:effect.xml">
        <SetVariable name="rack">1</SetVariable>
        <SetVariable name="unit">1</SetVariable>
        <SetVariable name="effect">3</SetVariable>
      </Template>
    </Children>
  </WidgetGroup>
</Template>
