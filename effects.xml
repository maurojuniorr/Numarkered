<Template>
  <WidgetGroup>
    <ObjectName>BeatFX_Container</ObjectName>
    <Layout>vertical</Layout>
    <Size>150f,0me</Size> <SizePolicy>min,me</SizePolicy>

    <Connection>
      <ConfigKey>[Skin],show_effects</ConfigKey>
      <BindProperty>visible</BindProperty>
    </Connection>

    <Children>
      
      <!-- <WidgetGroup>
        <ObjectName>BeatFX_Header</ObjectName>
        <Layout>vertical</Layout>
        <Size>0me,16p</Size>
        <Children>
          <Label><ObjectName>BeatFX_Title</ObjectName><Text>EFFECTS</Text></Label>
        </Children>
      </WidgetGroup> -->

      <Template src="skin:effect.xml">
        <SetVariable name="rack">1</SetVariable>
        <SetVariable name="unit">1</SetVariable>
        <SetVariable name="effect">1</SetVariable>
      </Template>
      
      <WidgetGroup>
        <ObjectName>BeatFX_BottomControls_U1</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>BeatFX_MasterSection</ObjectName>
            <Layout>vertical</Layout>
            <Children>
              <!-- <Label><ObjectName>BeatFX_ChannelSelectLabel</ObjectName><Text>FX 1 MASTER</Text></Label> -->
              <VuMeter>
                <ObjectName>EffectMeter</ObjectName>
                <Size>0me,6max</Size>
                <Connection><ConfigKey>[EffectRack1_EffectUnit1],mix</ConfigKey></Connection>
              </VuMeter>
            </Children>
          </WidgetGroup>

          <WidgetGroup>
            <ObjectName>BeatFX_ChannelSelect</ObjectName>
            <Layout>vertical</Layout>
            <Children>
              <Label><ObjectName>BeatFX_ChannelSelectLabel</ObjectName><Text>ASSIGN</Text></Label>
              <WidgetGroup>
                <ObjectName>BeatFX_ChannelButtons</ObjectName>
                <Layout>horizontal</Layout>
                <Children>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>1</Text></State><State><Number>1</Number><Text>1</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit1],group_[Channel1]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>2</Text></State><State><Number>1</Number><Text>2</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit1],group_[Channel2]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>3</Text></State><State><Number>1</Number><Text>3</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit1],group_[Channel3]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>4</Text></State><State><Number>1</Number><Text>4</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit1],group_[Channel4]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <WidgetGroup><Size>0me,8p</Size></WidgetGroup>

      <Template src="skin:effect.xml">
        <SetVariable name="rack">1</SetVariable>
        <SetVariable name="unit">2</SetVariable>
        <SetVariable name="effect">1</SetVariable>
      </Template>
      
      <WidgetGroup>
        <ObjectName>BeatFX_BottomControls_U2</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>BeatFX_MasterSection</ObjectName>
            <Layout>vertical</Layout>
            <Children>
              <!-- <Label><ObjectName>BeatFX_ChannelSelectLabel</ObjectName><Text>FX 2 MASTER</Text></Label> -->
              <VuMeter>
                <ObjectName>EffectMeter</ObjectName>
                <Size>0me,6max</Size>
                <Connection><ConfigKey>[EffectRack1_EffectUnit2],mix</ConfigKey></Connection>
              </VuMeter>
            </Children>
          </WidgetGroup>

          <WidgetGroup>
            <ObjectName>BeatFX_ChannelSelect</ObjectName>
            <Layout>vertical</Layout>
            <Children>
              <Label><ObjectName>BeatFX_ChannelSelectLabel</ObjectName><Text>ASSIGN</Text></Label>
              <WidgetGroup>
                <ObjectName>BeatFX_ChannelButtons</ObjectName>
                <Layout>horizontal</Layout>
                <Children>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>1</Text></State><State><Number>1</Number><Text>1</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit2],group_[Channel1]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>2</Text></State><State><Number>1</Number><Text>2</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit2],group_[Channel2]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>3</Text></State><State><Number>1</Number><Text>3</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit2],group_[Channel3]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                  <PushButton><Size>0me,25p</Size><NumberStates>2</NumberStates><State><Number>0</Number><Text>4</Text></State><State><Number>1</Number><Text>4</Text></State><Connection><ConfigKey>[EffectRack1_EffectUnit2],group_[Channel4]_enable</ConfigKey><ConnectValueToWidget>true</ConnectValueToWidget></Connection></PushButton>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

    </Children>
  </WidgetGroup>
</Template>