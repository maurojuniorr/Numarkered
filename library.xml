<Template>
  <WidgetGroup>
    <SizePolicy>me,e</SizePolicy>
    <Layout>vertical</Layout>
    <Children>
      
      <WidgetGroup>
        <ObjectName>LibraryWrapper</ObjectName> <Layout>vertical</Layout>
        <Size>0me,40p</Size>
        <Children>
          
          <WidgetGroup>
            <ObjectName>SidebarContainer</ObjectName> 
            <Layout>horizontal</Layout>
            <Size>0me,30max</Size>
            <Children>
              
              
              <SearchBox>
                <ObjectName>SearchBox</ObjectName>
                <Size>0me,30max</Size>
                <SizePolicy>me,me</SizePolicy> 
              </SearchBox>
              
              <PushButton>
                <ObjectName>SidebarButton</ObjectName>
                <Size>80p,30p</Size>
                <NumberStates>2</NumberStates>
                <State><Number>0</Number><Text>Sidebar</Text></State>
                <State><Number>1</Number><Text>Sidebar</Text></State>
                <Connection>
                  <ConfigKey>[Sidebar],sidebar_visible</ConfigKey>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <WidgetGroup>
            <Layout>horizontal</Layout>
            <Size>0me,0me</Size>
            <Children>
              
              <WidgetGroup>
                <ObjectName>SidebarWrapper</ObjectName> 
                <Layout>horizontal</Layout>
                <Size>190me,0me</Size>
                <SizePolicy>max,me</SizePolicy>
                <MaximumSize>190,9999</MaximumSize>
                <Children>
                  <LibrarySidebar>
                    <ObjectName>LibrarySidebar</ObjectName>
                  </LibrarySidebar>
                </Children>
                <Connection>
                  <ConfigKey>[Sidebar],sidebar_visible</ConfigKey>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </WidgetGroup>

              <WidgetGroup>
                <ObjectName>LibraryTableContainer</ObjectName>
                <Layout>horizontal</Layout>
                <SizePolicy>me,me</SizePolicy> <Children>
                    <Library>
                        <ObjectName>Library</ObjectName>
                    </Library>
                </Children>
            </WidgetGroup>

            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <WidgetGroup>
        <ObjectName>Decks</ObjectName> <Layout>horizontal</Layout>
        <Size>0me,85max</Size>
        <Children>
          
          <WidgetGroup>
            <Layout>stacked</Layout>
            <SizePolicy>me,me</SizePolicy>
            <Children>
              <WidgetGroup>
                <Layout>horizontal</Layout>
                <Children><Template src="skin:deck.xml"><SetVariable name="channel">1</SetVariable></Template></Children>
                <Connection>
                  <ConfigKey>[Skin],layer_left</ConfigKey>
                  <BindProperty>visible</BindProperty>
                  <Transform><Not/></Transform>
                </Connection>
              </WidgetGroup>
              <WidgetGroup>
                <Layout>horizontal</Layout>
                <Children><Template src="skin:deck.xml"><SetVariable name="channel">3</SetVariable></Template></Children>
                <Connection>
                  <ConfigKey>[Skin],layer_left</ConfigKey>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </WidgetGroup>
            </Children>
          </WidgetGroup>

          <WidgetGroup>
            <Layout>stacked</Layout>
            <SizePolicy>me,me</SizePolicy>
            <Children>
              <WidgetGroup>
                <Layout>horizontal</Layout>
                <Children><Template src="skin:deck.xml"><SetVariable name="channel">2</SetVariable></Template></Children>
                <Connection>
                  <ConfigKey>[Skin],layer_right</ConfigKey>
                  <BindProperty>visible</BindProperty>
                  <Transform><Not/></Transform>
                </Connection>
              </WidgetGroup>
              <WidgetGroup>
                <Layout>horizontal</Layout>
                <Children><Template src="skin:deck.xml"><SetVariable name="channel">4</SetVariable></Template></Children>
                <Connection>
                  <ConfigKey>[Skin],layer_right</ConfigKey>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
          
        </Children>
      </WidgetGroup>

    </Children>
  </WidgetGroup>
</Template>