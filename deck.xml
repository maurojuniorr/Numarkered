<Template>
  <WidgetGroup>
    <ObjectName>Deck</ObjectName>
    <Layout>vertical</Layout>
    <Size>380me,50me</Size>
    
    <Connection>
      <ConfigKey>[Skin],layer_<Variable name="side"/></ConfigKey>
      <BindProperty>highlight</BindProperty>
    </Connection>
   
    <Children>
      <WidgetGroup>
        <ObjectName>DeckHotcuesContainer</ObjectName>
        <Layout>vertical</Layout>
        <SizePolicy>me,min</SizePolicy>
        <Children>
          <Template src="skin:hotcue_bank.xml">
            <SetVariable name="channel"><Variable name="channel"/></SetVariable>
          </Template>
        </Children>
        <Connection>
          <ConfigKey>[Tab],overview</ConfigKey>
          <BindProperty>visible</BindProperty>
        </Connection>
      </WidgetGroup>

      <WidgetGroup>
        <ObjectName>DeckHeader</ObjectName>
        <Connection>
          <ConfigKey>[Skin],layer_<Variable name="side"/></ConfigKey>
          <BindProperty>highlight</BindProperty>
        </Connection>
        <Layout>horizontal</Layout>
        <SizePolicy>me,f</SizePolicy>
        <MaximumSize>-1,28</MaximumSize>
        <Children>
          <WidgetGroup>
            <ObjectName>DeckChannelTitleWrapper</ObjectName>
            <Layout>horizontal</Layout>
            <SizePolicy>f,f</SizePolicy>
            <Size>100f,28f</Size>
            <MinimumSize>100,28</MinimumSize>
            <MaximumSize>100,28</MaximumSize>
            <Children>
              <Label>
                <ObjectName>DeckPlayingLeft</ObjectName>
                <Text>((</Text>
                                <SizePolicy>f,f</SizePolicy>
                                <Connection>
                  <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
                  <BindProperty>highlight</BindProperty>
                </Connection>
              </Label>
              <PushButton>
                <ObjectName>DeckChannelTitle</ObjectName>
                <Size>60f,22f</Size>
                                <NumberStates>2</NumberStates> 
                <State>
                  <Number>0</Number>
                  <Text>DECK <Variable name="channel"/></Text>
                </State>
                <State>
                  <Number>1</Number>
                  <Text>DECK <Variable name="channel"/></Text>
                </State>
                <Connection>
                  <ConfigKey>[Skin],layer_<Variable name="side"/></ConfigKey>
                  <EmitOnPressAndRelease>true</EmitOnPressAndRelease>
                  <ButtonState>LeftButton</ButtonState>
                </Connection>
                <Connection>
                  <ConfigKey>[Skin],layer_<Variable name="side"/></ConfigKey>
                  <BindProperty>highlight</BindProperty>
                </Connection>
              </PushButton>
              <Label>
                <ObjectName>DeckPlayingRight</ObjectName>
                <Text>))</Text>
                                <SizePolicy>f,f</SizePolicy>
                                <Connection>
                  <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
                  <BindProperty>highlight</BindProperty>
                </Connection>
              </Label>
            </Children>
          </WidgetGroup>

          <WidgetGroup>
            <ObjectName>DeckTitleWrapper</ObjectName>
            <Layout>horizontal</Layout>
            <SizePolicy>me,f</SizePolicy>
            <Children>
              <Label>
                <ObjectName>DeckTitleNote</ObjectName>
                <Connection>
                  <ConfigKey>[Skin],layer_<Variable name="side"/></ConfigKey>
                  <BindProperty>highlight</BindProperty>
                </Connection>
                <Text>♪</Text>
                <SizePolicy>f,f</SizePolicy>
              </Label>
              <TrackProperty>
                <ObjectName>DeckTitle</ObjectName>
                <TooltipId>track_title</TooltipId>
                <Size>380me,-1</Size>
                <Scrolling>true</Scrolling>
                <Property>title</Property>
                <Channel><Variable name="channel"/></Channel>
                <Elide>right</Elide>
              </TrackProperty>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <WidgetGroup>
        <ObjectName>DeckInfo</ObjectName>
        <Layout>horizontal</Layout>
        <SizePolicy>me,me</SizePolicy>
        <Children>
          <WidgetGroup><Size>1f,0me</Size><SizePolicy>f,me</SizePolicy></WidgetGroup>

          <Template src="skin:deck_spinny.xml">
            <SetVariable name="channel"><Variable name="channel"/></SetVariable>
          </Template>

          <WidgetGroup><Size>2f,0me</Size><SizePolicy>f,me</SizePolicy></WidgetGroup>

          <WidgetGroup>
            <ObjectName>InfoAndOverviewTower</ObjectName>
            <Layout>vertical</Layout>
            <SizePolicy>me,me</SizePolicy>
            <Children>

              <WidgetGroup>
                <ObjectName>DeckDataRow</ObjectName>
                <Layout>horizontal</Layout>
                <SizePolicy>me,min</SizePolicy>
                <Children>
                  
                  <WidgetGroup>
                    <ObjectName>TrackTimeContainer</ObjectName>
                    <Layout>vertical</Layout>
                    <SizePolicy>me,me</SizePolicy>
                    <Children>
                      <Label>
                        <ObjectName>DeckTrackTimeTitle</ObjectName>
                        <Text>Time</Text>
                        <SizePolicy>me,f</SizePolicy>
                      </Label>
                      <WidgetGroup>
                        <ObjectName>DeckTrackTimeWrapper</ObjectName>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,me</SizePolicy>
                        <Align>left</Align>
                        <Children>
                          <SizeAwareStack>
                            <SizePolicy>me,me</SizePolicy>
                            <Children>
                              <NumberPos>
                                <ObjectName>DeckTrackTimeMini</ObjectName>
                                <MaximumSize>150,-1</MaximumSize>
                                <SizePolicy>me,me</SizePolicy>
                                <NumberOfDigits>6</NumberOfDigits>
                                <Channel><Variable name="channel"/></Channel>
                                <Connection>
                                  <ConfigKey>[Channel<Variable name="channel"/>],end_of_track</ConfigKey>
                                  <BindProperty>highlight</BindProperty>
                                </Connection>
                              </NumberPos>
                              <NumberPos>
                                <ObjectName>DeckTrackTime</ObjectName>
                                <SizePolicy>me,me</SizePolicy>
                                <NumberOfDigits>6</NumberOfDigits>
                                <Channel><Variable name="channel"/></Channel>
                                <Connection>
                                  <ConfigKey>[Channel<Variable name="channel"/>],end_of_track</ConfigKey>
                                  <BindProperty>highlight</BindProperty>
                                </Connection>
                              </NumberPos>
                            </Children>
                          </SizeAwareStack>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetGroup>
                  
                  <WidgetGroup>
                    <ObjectName>TrackBPMRangeContainer</ObjectName>
                    <Layout>vertical</Layout>
                    <SizePolicy>f,min</SizePolicy>
                    <MaximumSize>90,-1</MaximumSize>
                    <Align>top</Align> 
                    <Children> 
                      <Label>
                        <ObjectName>DeckTempoTitle</ObjectName> 
                        <Text>PITCH</Text>
                        <SizePolicy>me,min</SizePolicy>
                        <Size>-1,14p</Size> 
                        <Align>left</Align>
                      </Label>           
                      <WidgetGroup>
                        <ObjectName>DeckBPMRangePercent</ObjectName>
                        <Layout>horizontal</Layout>
                        <Size>15,16p</Size>
                        <MinimumSize>15,-1</MinimumSize>
                        <Children>
                          <Label><ObjectName>BPMRangePlusMinus</ObjectName><Text>±</Text><SizePolicy>f,min</SizePolicy></Label>
                          <RateRange>
                            <ObjectName>RateDisplay</ObjectName>
                            <SizePolicy>me,min</SizePolicy>
                            <Channel><Variable name="channel" /></Channel>
                            <Display>range</Display>
                          </RateRange>
                        </Children>
                      </WidgetGroup>
                      <WidgetGroup>
                        <ObjectName>RateDisplay<Variable name="channel"/></ObjectName>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                          <NumberRate>
                            <SizePolicy>me,min</SizePolicy>
                            <Channel><Variable name="channel"/></Channel>
                            <NumberOfDigits>1</NumberOfDigits>
                          </NumberRate>
                          <Label><ObjectName>BPMPercent</ObjectName><Text>%</Text><SizePolicy>f,min</SizePolicy></Label>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetGroup>

                  <WidgetGroup>
                    <ObjectName>TrackBPMContainer</ObjectName>
                    <Layout>vertical</Layout>
                    <SizePolicy>f,min</SizePolicy>
                    <MaximumSize>90,-1</MaximumSize>
                    <Align>top</Align> 
                    <Children>
                      <Label>
                        <ObjectName>DeckTempoTitle</ObjectName>
                        <Text>TEMPO</Text> <SizePolicy>me,min</SizePolicy>
                        <Size>-1,14p</Size>
                        <Align>left</Align>
                      </Label>
                      <WidgetGroup>
                        <ObjectName>DeckBPMWrapper</ObjectName>
                        <Layout>vertical</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Align>center</Align>
                        <Children>
                          <NumberBpm>
                            <ObjectName>DeckBPM</ObjectName>
                            <TooltipId>visual_bpm</TooltipId>
                            <SizePolicy>me,me</SizePolicy>
                            <Channel><Variable name="channel"/></Channel>
                            <Connection>
                              <ConfigKey>[Channel<Variable name="channel"/>],visual_bpm</ConfigKey>
                            </Connection>
                          </NumberBpm>
                          <WidgetGroup>
                            <ObjectName>DeckBPMTitleWrapper</ObjectName>
                            <Layout>horizontal</Layout>
                            <SizePolicy>me,min</SizePolicy>
                            <Children>
                              <Label>
                              <ObjectName>DeckBPMTitle</ObjectName>
                              <Text>BPM</Text>
                              <SizePolicy>me,min</SizePolicy>
                            </Label>
                            </Children>
                          </WidgetGroup>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetGroup>

                </Children>
              </WidgetGroup> 

              <Template src="skin:deck_overview.xml">
                <SetVariable name="channel"><Variable name="channel"/></SetVariable>
              </Template>

            </Children>
            <Connection>
              <ConfigKey>[Tab],overview</ConfigKey>
              <BindProperty>visible</BindProperty>
            </Connection>
          </WidgetGroup>
          
        </Children>
      </WidgetGroup>
    </Children>
  </WidgetGroup>
</Template>